{
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "Argus Phishing Detection Platform — Observability Dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "barchart",
      "title": "Phishing Detections by Plan Tier",
      "description": "phishing_detections_total segmented by tenant plan — low-cardinality view of detection volume.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": { "orientation": "auto", "xTickLabelRotation": 0 },
      "targets": [
        {
          "expr": "sum by (tenant_plan) (increase(phishing_detections_total[$__range]))",
          "legendFormat": "{{ tenant_plan }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "heatmap",
      "title": "Scan Latency Distribution",
      "description": "Heat map of end-to-end scan latency buckets over time.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": { "calculate": false, "color": { "scheme": "Oranges" } },
      "targets": [
        {
          "expr": "sum(rate(scan_latency_seconds_bucket[$__rate_interval])) by (le)",
          "legendFormat": "{{ le }}",
          "refId": "A",
          "format": "heatmap"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Worker Queue Backlog (queue_depth)",
      "description": "Current number of pending jobs per worker.",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "expr": "queue_depth",
          "legendFormat": "{{ worker }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "histogram",
      "title": "Queue Wait Time Distribution",
      "description": "P50/P95/P99 wait time before a job is picked up by the worker.",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, worker) (rate(queue_wait_seconds_bucket[$__rate_interval])))",
          "legendFormat": "P50 {{ worker }}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, worker) (rate(queue_wait_seconds_bucket[$__rate_interval])))",
          "legendFormat": "P95 {{ worker }}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, worker) (rate(queue_wait_seconds_bucket[$__rate_interval])))",
          "legendFormat": "P99 {{ worker }}",
          "refId": "C"
        }
      ]
    },
    {
      "id": 5,
      "type": "state-timeline",
      "title": "Worker Heartbeat Status",
      "description": "Shows when each worker last emitted a heartbeat. Red = stale (>5 min).",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": {
        "mergeValues": false,
        "rowHeight": 0.9,
        "showValue": "always"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 0 }
            ]
          },
          "unit": "dateTimeFromNow"
        }
      },
      "targets": [
        {
          "expr": "worker_heartbeat",
          "legendFormat": "{{ worker }}",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Threat Intelligence Alert Volume (by Detection Type)",
      "description": "Rate of alerts generated by CT log, NRD, and threat feed workers.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 21 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (detection_type) (rate(threat_intel_alerts_total[$__rate_interval]))",
          "legendFormat": "{{ detection_type }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "type": "bargauge",
      "title": "Model Inference Latency P95 by Detector",
      "description": "P95 inference time per sub-detector (url, html, visual, classical).",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 21 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": { "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 1.0 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, detector) (rate(model_inference_latency_seconds_bucket[$__rate_interval])))",
          "legendFormat": "{{ detector }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "type": "piechart",
      "title": "Sandbox Runs by Status",
      "description": "Distribution of sandbox runs across queued / completed / failed statuses.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": { "pieType": "pie", "displayLabels": ["name", "percent"] },
      "targets": [
        {
          "expr": "sum by (status) (increase(sandbox_runs_total[$__range]))",
          "legendFormat": "{{ status }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Worker Failure Rate",
      "description": "Failures per minute for each worker over the selected time range.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 0.5 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum by (worker) (rate(worker_failures_total[$__rate_interval]))",
          "legendFormat": "{{ worker }}",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["argus", "phishing", "observability"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Argus — Phishing Detection Observability",
  "uid": "argus-observability-v1",
  "version": 1
}
